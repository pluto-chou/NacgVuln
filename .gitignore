.ruff_cache/

# Virtual environments
.venv/
venv/
ENV/
conda-env/
*.egg-info/

# IDE and OS files
.idea/
.vscode/
.DS_Store
Thumbs.db

# Logs and temporary outputs
*.log
nohup.out
output_*.log
logs/
runs/
runs_*/
